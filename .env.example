# Runtime
PORT=8080
UPDATE_INTERVAL_HOURS=6
THRESHOLD_EUR=5
OUTPUT_FILE=/data/cost-status.json
STATE_FILE=/data/alert-state.json

# Slack notifications (incoming webhook URL)
SLACK_WEBHOOK_URL=

# Demo mode (recommended until real credentials are available)
USE_MOCK_DATA=true
MOCK_ORACLE_EUR=1.25
MOCK_CLOUDFLARE_EUR=0.80

# Oracle placeholders (required for future live adapter)
ORACLE_TENANT_ID=
ORACLE_USER_OCID=
ORACLE_FINGERPRINT=
ORACLE_PRIVATE_KEY_PATH=
ORACLE_REGION=

# Cloudflare live API
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
